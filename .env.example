BOT_TOKEN=''
SEMANTIC_SCHOLAR=''

# --- LLM (Ollama локально) ---
LLM_ENABLED=true
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3.1

# --- Antiplagiarism matching ---
# How many found sources should be downloaded and compared as full text.
ANTIPLAGIARISM_SOURCE_LIMIT=12
ANTIPLAGIARISM_SOURCE_PARALLEL=3
ANTIPLAGIARISM_SOURCE_TIMEOUT_MS=9000
ANTIPLAGIARISM_SOURCE_MAX_BYTES=3145728
ANTIPLAGIARISM_SHINGLE_SIZE=5

# --- Web auth email (SMTP) ---
WEB_PORT=3000
MAIL_FROM=SourceMate <user@example.com>
MAIL_DEV_FALLBACK=false

# Recommended for local development: Brevo sends over HTTPS, so it works when SMTP ports are blocked.
BREVO_API_KEY=

# Optional SMTP fallback.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=app-password
SMTP_FROM=SourceMate <user@example.com>
